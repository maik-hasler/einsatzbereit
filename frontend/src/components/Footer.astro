---
import { Icon } from 'astro-icon/components';

const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-800 text-brand-200">
  <div class="max-w-7xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Brand -->
      <div>
        <h2 class="text-white text-2xl font-bold mb-4">Einsatzbereit</h2>
        <p class="text-sm leading-relaxed max-w-xs">
          Einsatzbereit bringt engagierte Helfer:innen mit regionalen Bedarfen zusammen. Spontan, schnell und wirksam.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-white font-semibold mb-4 uppercase text-xs tracking-wider">Plattform</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Einsätze finden</a></li>
          <li><a href="/api/login" class="hover:text-white transition-colors">Mitmachen</a></li>
        </ul>

        <h3 class="text-white font-semibold mb-4 mt-6 uppercase text-xs tracking-wider">Rechtliches</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/impressum" class="hover:text-white transition-colors">Impressum</a></li>
          <li><a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="text-white font-semibold mb-4 uppercase text-xs tracking-wider">Folge uns</h3>
        <div class="flex space-x-4">
          <a href="https://github.com/maikhoepfel/einsatzbereit" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-brand-200 hover:text-white transition-colors">
            <Icon name="simple-icons:github" class="w-6 h-6" />
          </a>
          <a href="#" aria-label="Instagram" class="text-brand-200 hover:text-white transition-colors">
            <Icon name="simple-icons:instagram" class="w-6 h-6" />
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-brand-700 text-center text-xs">
      <p>&copy; {currentYear} Einsatzbereit. Alle Rechte vorbehalten.</p>
    </div>
  </div>
</footer>
