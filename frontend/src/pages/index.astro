---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Einsatzbereit — Spontanes Ehrenamt in deiner Nähe"
  description="Entdecke kurzfristige Ehrenamt-Einsätze bei gemeinnützigen Organisationen in deiner Nähe. Melde dich spontan an und hilf dort, wo du gerade gebraucht wirst."
>
  <main class="mx-auto max-w-2xl px-4 py-16 text-center">
    <h1 class="mb-4 text-4xl font-bold">Einsatzbereit</h1>
    <p class="mb-8 text-lg text-gray-600">
      Engagiere dich spontan. Finde Ehrenamt-Einsätze in deiner Nähe.
    </p>
    <a
      href="/bedarfe"
      class="inline-block rounded-lg bg-blue-600 px-6 py-3 font-semibold text-white transition hover:bg-blue-700"
    >
      Bedarfe entdecken
    </a>
  </main>
</BaseLayout>
