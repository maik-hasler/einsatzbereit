# PostgreSQL
POSTGRES_DB=einsatzbereit
POSTGRES_USER=einsatzbereit
POSTGRES_PASSWORD=einsatzbereit

# Keycloak
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/einsatzbereit
KC_DB_USERNAME=einsatzbereit
KC_DB_PASSWORD=einsatzbereit
KC_HOSTNAME=localhost

# Backend
ASPNETCORE_ENVIRONMENT=Development
Authentication__Authority=http://keycloak:8080/realms/einsatzbereit
ConnectionStrings__DefaultConnection=Host=postgres;Database=einsatzbereit;Username=einsatzbereit;Password=einsatzbereit

# Frontend
API_URL=http://backend:8080
